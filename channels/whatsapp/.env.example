# WhatsApp Business API Configuration
# Get these from Meta Business Suite > WhatsApp > API Setup

# Your WhatsApp Business Phone Number ID
WHATSAPP_PHONE_NUMBER_ID=

# Access Token (System User Token recommended for production)
WHATSAPP_ACCESS_TOKEN=

# Webhook Verify Token (you create this - any random string)
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# App Secret (for webhook signature verification)
WHATSAPP_APP_SECRET=

# Business Account ID (optional, for some API calls)
WHATSAPP_BUSINESS_ACCOUNT_ID=

# API Version
WHATSAPP_API_VERSION=v21.0
